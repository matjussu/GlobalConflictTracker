rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Development: allow all reads and writes (TEMPORARY)
    // TODO: Lock down writes for production
    match /events/{eventId} {
      allow read: if true;
      allow write: if true;
    }
    match /factions/{factionId} {
      allow read: if true;
      allow write: if true;
    }
    match /intelReports/{reportId} {
      allow read: if true;
      allow write: if true;
    }
    match /regions/{regionId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
